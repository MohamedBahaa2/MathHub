NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://mathhub:mathhub@localhost:5432/mathhub?schema=public

# JWT
ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters-here
REFRESH_TOKEN_SECRET=replace-with-another-32-random-characters-here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# CORS / Cookies
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=
TRUST_PROXY=false
LOG_LEVEL=info

# AES-256 Encryption for Zoom URLs (generate: openssl rand -hex 32)
ENCRYPTION_KEY=replace-with-64-hex-chars-openssl-rand-hex-32

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET_ASSIGNMENTS=assignments
SUPABASE_BUCKET_MATERIALS=materials
SUPABASE_BUCKET_QUIZ_MEDIA=quiz-media

# PayTabs
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=ARE
PAYTABS_RETURN_URL=https://yourdomain.com/payments/callback
PAYTABS_WEBHOOK_URL=https://api.yourdomain.com/api/payments/webhook

# Resend (password reset email only)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
